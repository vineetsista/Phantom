# === AI API Keys ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here  # Optional — falls back to OpenAI TTS

# === GitHub ===
GITHUB_TOKEN=your_github_token_here  # Optional — increases rate limit from 60 to 5000 req/hr

# === Database ===
DATABASE_URL=postgresql://phantom:phantom@localhost:5432/phantom

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === App ===
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
SECRET_KEY=change_this_to_a_random_64_char_string_in_production

# === Video Pipeline ===
VIDEO_OUTPUT_DIR=./output/videos
THUMBNAIL_OUTPUT_DIR=./output/thumbnails
TEMP_DIR=./output/temp
MAX_REPO_SIZE_MB=100
DEFAULT_VOICE=openai        # openai | elevenlabs
DEFAULT_QUALITY=720p        # 720p | 1080p
# ElevenLabs voice — defaults to Brian (warmer male, better for tech
# narration than the Rachel default). See https://elevenlabs.io/voice-library
# for IDs.
DEFAULT_ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5   # or eleven_multilingual_v2

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Frontend (Next.js public vars) ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Auth (v6) ===
# NextAuth — required when REQUIRE_AUTH=1 on the backend.
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
# Create at https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Backend feature flag — when 1, /api/v1/generate requires signed-in
# user and enforces monthly quota. Leave 0 during v6 rollout until the
# OAuth app is registered and frontend is wired.
REQUIRE_AUTH=0

# === Stripe (v6, Phase 2 — defer until ready to charge) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
