# ===========================================================================
# Phantom — example environment file.
# Copy to `.env` and fill in your own values. Everything marked OPTIONAL
# is a clean no-op when its key is missing.
# ===========================================================================

# --- AI keys (required for real renders) -----------------------------------
# Without ANTHROPIC_API_KEY the script generator falls back to a deterministic
# mock script — fine for verifying the pipeline runs, but the narration won't
# be specific to the repo.
ANTHROPIC_API_KEY=

# ElevenLabs is preferred — its `with-timestamps` endpoint returns word-level
# alignment which is what makes the visual sync tight. OPTIONAL.
ELEVENLABS_API_KEY=

# OpenAI TTS as a fallback if you don't have ElevenLabs. OPTIONAL.
OPENAI_API_KEY=

# OPTIONAL — bumps GitHub API rate limit from 60/hr (unauthenticated) to
# 5000/hr. Useful when generating many repos or hitting PR URLs.
GITHUB_TOKEN=

# --- NextAuth + GitHub OAuth (required for sign-in) ------------------------
# Create an OAuth app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_openssl_rand_base64_32
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Database + Redis (filled in by docker-compose, don't touch) -----------
DATABASE_URL=postgresql://phantom:phantom@db:5432/phantom
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- App URLs --------------------------------------------------------------
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
SECRET_KEY=change_this_to_a_random_64_char_string

# --- Voice pipeline defaults -----------------------------------------------
DEFAULT_VOICE=elevenlabs
DEFAULT_QUALITY=720p
# ElevenLabs voice ID — Antoni is the project default. See
# https://elevenlabs.io/voice-library for other IDs.
DEFAULT_ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Output dirs (paths inside the container) ------------------------------
VIDEO_OUTPUT_DIR=./output/videos
THUMBNAIL_OUTPUT_DIR=./output/thumbnails
TEMP_DIR=./output/temp
MAX_REPO_SIZE_MB=100

# --- Optional: observability + delivery infra ------------------------------
# All silent when their key is missing.

# Sentry — backend + browser error tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# PostHog — product analytics (EU region by default; honors Do Not Track)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Resend — transactional emails (welcome, generation complete)
RESEND_API_KEY=
RESEND_FROM=Phantom <hello@example.com>

# Cloudflare R2 — CDN delivery instead of serving MP4s from FastAPI.
# All five must be set together or none.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL_BASE=

# ElevenLabs monthly character budget (chars). When the running total
# hits this, voice_generator falls back to OpenAI TTS for the rest of
# the month. Default 1M ≈ $300/mo on the Creator tier.
ELEVENLABS_MONTHLY_CHAR_BUDGET=1000000
